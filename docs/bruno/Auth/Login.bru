meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{host}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "admin@genpos.com",
    "password": "password123"
  }
}

script:post-response {
  if (res.status === 200 && res.body.data && res.body.data.access_token) {
    bru.setVar("auth_token", res.body.data.access_token);
    console.log("Token saved to collection variable: auth_token");
  }
}
