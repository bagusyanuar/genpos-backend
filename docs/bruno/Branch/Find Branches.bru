meta {
  name: Find Branches
  type: http
  seq: 1
}

get {
  url: {{host}}/branches?search=&page=1&limit=10
  body: none
  auth: bearer
}

query {
  search: 
  page: 1
  limit: 10
}

auth:bearer {
  token: {{auth_token}}
}

docs {
  ### Response Examples
  
