  ```json
  {
    "success": true,
    "message": "branches found successfully",
    "data": [
      {
        "id": "uuid-branch-1",
        "name": "Main Store",
        "is_default": true,
        "created_at": "2026-04-15T...",
        "updated_at": "2026-04-15T..."
      }
    ],
    "pagination": {
      "current_page": 1,
      "total_page": 1,
      "total_data": 1,
      "limit": 10
    }
  }
  ```
}
