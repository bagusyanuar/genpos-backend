meta {
  name: Sync Material UOMs
  type: http
  seq: 7
}

put {
  url: {{host}}/materials/:id/uoms
  body: json
  auth: bearer
}

params:path {
  id: 
}

auth:bearer {
  token: {{auth_token}}
}

body:json {
  {
    "uoms": [
      {
        "unit_id": "uuid-unit-gram",
        "multiplier": 1,
        "is_default": true
      },
      {
        "unit_id": "uuid-unit-kg",
        "multiplier": 1000,
        "is_default": false
      }
    ]
  }
}

docs {
  ### Response Examples
  
  #### 🟢 200 OK
  ```json
  {
    "success": true,
    "message": "material UOMs synced successfully",
    "data": null
  }
  ```
}
