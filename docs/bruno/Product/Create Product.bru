    "is_active": true,
    "variants": [
      {
        "name": "Regular",
        "sku": "COF-ARN-01",
        "price": 25000,
        "is_active": true
      },
      {
        "name": "Large",
        "sku": "COF-ARN-02",
        "price": 30000,
        "is_active": true
      }
    ],
    "branch_ids": ["aebe8670-b513-4ff2-854b-d70521bcf85b"]
  }
}

