meta {
  name: Create Product
  type: http
  seq: 3
}

post {
  url: {{host}}/products
  body: json
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

body:json {
  {
    "name": "Kopi Susu Gula Aren",
    "description": "Black coffee with water",
