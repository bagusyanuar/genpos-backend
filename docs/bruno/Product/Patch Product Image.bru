meta {
  name: Patch Product Image
  type: http
  seq: 5
}

patch {
  url: {{host}}/products/:id/image
  body: multipartForm
  auth: bearer
}

params:path {
  id: 
}

auth:bearer {
  token: {{auth_token}}
}

body:multipart-form {
  image: @file()
}

docs {
  ### Response Examples
  
  #### 🟢 200 OK
  ```json
  {
    "success": true,
    "message": "image updated successfully",
    "data": {
      "image_url": "public/products/random-filename.png"
    }
  }
  ```
}
