			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{auth_token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{base_url}}/branches/:id",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"branches",
						":id"
					],
					"variable": [
						{
							"key": "id",
							"value": "uuid-here"
						}
					]
				}
			},
			"response": []
		}
	]
}
