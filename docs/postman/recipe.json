{
	"info": {
		"_postman_id": "genpos-recipe-v1",
		"name": "GenPOS - Recipe Module",
		"description": "Recipe management and COGS calculation",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Sync Recipe",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{auth_token}}",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"recipes\": [\n        {\n            \"material_id\": \"uuid-material-1\",\n            \"uom_id\": \"uuid-uom-1\",\n            \"quantity\": 2.5,\n            \"subtotal_cost\": 0\n        },\n        {\n            \"material_id\": \"uuid-material-2\",\n            \"uom_id\": \"uuid-uom-2\",\n            \"quantity\": 1.0,\n            \"subtotal_cost\": 5000\n        }\n    ]\n}"
				},
				"url": {
					"raw": "{{host}}/recipes/variant/:variant_id",
					"host": [
						"{{host}}"
					],
					"path": [
						"recipes",
						"variant",
						":variant_id"
					],
					"variable": [
						{
							"key": "variant_id",
							"value": ""
						}
					]
				}
			},
			"response": []
		},
		{
			"name": "Get Recipes By Variant ID",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{auth_token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{host}}/recipes/variant/:variant_id",
					"host": [
						"{{host}}"
					],
					"path": [
						"recipes",
						"variant",
						":variant_id"
					],
					"variable": [
						{
							"key": "variant_id",
							"value": ""
						}
					]
				}
			},
			"response": []
		},
		{
			"name": "Calculate COGS",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{auth_token}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "{{host}}/recipes/variant/:variant_id/cogs",
					"host": [
						"{{host}}"
					],
					"path": [
						"recipes",
						"variant",
						":variant_id",
						"cogs"
					],
					"variable": [
						{
							"key": "variant_id",
							"value": ""
						}
					]
				}
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "host",
			"value": "http://localhost:8080/api/v1",
			"type": "string"
		},
		{
			"key": "auth_token",
			"value": "",
			"type": "string"
		}
	]
}
